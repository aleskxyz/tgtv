# Native dev defaults — set -a; source dev/.env; set +a (see dev/README.md)

# --- Paths (repo-relative) ---
SESSION_DIR=./session
CONFIG_DIR=./config
SESSION_NAME=tgtv

# --- HTTP API ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8090
PATH_SECRET=dev-path-secret-change-me

# --- Client URL (no Caddy in dev) ---
PUBLIC_BASE_URL=http://127.0.0.1:8090

# --- Caddy (unused by native binary) ---
CADDY_DOMAIN=:80
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
SHORT_PLAYLIST_PATH=/devplaylist

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=jsonl
TELEGRAM_LOG_LEVEL=warn

# --- Discovery ---
SCAN_DIALOG_DELAY_SECONDS=0.35
FULL_SCAN_INTERVAL_SECONDS=3600

# --- Ingest ---
MAX_CONCURRENT_INGESTS=10
IDLE_GRACE_SECONDS=60
INGEST_START_STAGGER_SECONDS=3
INGEST_INPUT_REJOIN_SECONDS=30
INGEST_REBUFFER_SECONDS=3
INGEST_STARTUP_GRACE_SECONDS=15
INGEST_OUTPUT_RECOVER_COOLDOWN_SECONDS=1
INGEST_RECOVERY_HOLD_SECONDS=90

# --- MediaMTX (dev/docker-compose.dev.yml on localhost) ---
RTMP_BASE_URL=rtmp://127.0.0.1:1935/live
MEDIAMTX_HLS_URL=http://127.0.0.1:8888
MEDIAMTX_HLS_CDN_SECRET=change-me-mediamtx-cdn-secret
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_LOG_LEVEL=info

# Docker / production install template (also written by ./tgtv.sh to ${INSTALL_DIR}/.env).
# Native development: see dev/README.md and dev/.env (Telegram creds via export).

# --- Telegram (required) ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_from_my.telegram.org

# --- Paths (container volume mount targets) ---
SESSION_DIR=/data/session
CONFIG_DIR=/data/config
SESSION_NAME=tgtv

# --- HTTP API (tgtv listens inside the Docker network) ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8090
# Path secret for /p/{secret}/… URLs (required for Caddy; must match tgtv)
PATH_SECRET=change-me-to-a-long-random-string

# --- Public URL (what clients see — must match Caddy edge, include :port if not 80/443) ---
PUBLIC_BASE_URL=http://127.0.0.1

# --- Caddy (public edge) ---
# Use :80 for HTTP on all interfaces, or your domain for automatic HTTPS (e.g. tv.example.com)
CADDY_DOMAIN=:80
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# Short playlist URL for TV/IPTV apps (Caddy redirects to /p/{PATH_SECRET}/playlist.m3u)
SHORT_PLAYLIST_PATH=/AbCdEfGh

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=jsonl
TELEGRAM_LOG_LEVEL=warn

# --- Discovery ---
SCAN_DIALOG_DELAY_SECONDS=0.35
FULL_SCAN_INTERVAL_SECONDS=3600

# --- Ingest ---
MAX_CONCURRENT_INGESTS=10
IDLE_GRACE_SECONDS=60
INGEST_START_STAGGER_SECONDS=3
INGEST_INPUT_REJOIN_SECONDS=30
INGEST_REBUFFER_SECONDS=3
INGEST_STARTUP_GRACE_SECONDS=15
INGEST_OUTPUT_RECOVER_COOLDOWN_SECONDS=1
INGEST_RECOVERY_HOLD_SECONDS=90

# --- MediaMTX / RTMP (Docker service hostnames) ---
RTMP_BASE_URL=rtmp://mediamtx:1935/live
MEDIAMTX_HLS_URL=http://mediamtx:8888
MEDIAMTX_HLS_CDN_SECRET=change-me-mediamtx-cdn-secret
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_LOG_LEVEL=info
